# Populate these in .env.local before running --live.
# Without keys the harness runs in --dry mode (plans renders, uploads nothing).

HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=            # Avatar IV character you've selected (see HeyGen Studio)
HEYGEN_VOICE_ID=             # HeyGen voice id; we mute this and overlay ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=         # Warm, calm, mid-paced UK English voice id

# Supabase service-role key is needed so the uploader can write to private
# tpm-videos / tpm-voice / tpm-cards buckets bypassing RLS.
SUPABASE_URL=https://kpsxdpxehorbjzgkkjqy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # Project Settings → API → service_role key
